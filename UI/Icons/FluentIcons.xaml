    <!-- Path style for Fluent icons - theme-colored via IconForegroundBrush -->
    <Style x:Key="FluentIconPathStyle" TargetType="Path">
        <Setter Property="Width" Value="24"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="Fill" Value="{DynamicResource IconForegroundBrush}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>
