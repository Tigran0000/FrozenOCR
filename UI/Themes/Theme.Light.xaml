<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="App.Background" Color="#FFF3F3F3"/>
    <SolidColorBrush x:Key="App.Backdrop" Color="#66000000"/>
    <SolidColorBrush x:Key="App.Dim" Color="#66000000"/>

    <SolidColorBrush x:Key="Surface.Background" Color="#E6FFFFFF"/>
    <SolidColorBrush x:Key="Surface.BackgroundAlt" Color="#CCFFFFFF"/>
    <SolidColorBrush x:Key="Surface.Border" Color="#22000000"/>

    <SolidColorBrush x:Key="Text.Primary" Color="#FF1A1A1A"/>
    <SolidColorBrush x:Key="Text.Secondary" Color="#FF5A5A5A"/>

    <SolidColorBrush x:Key="Accent" Color="#FF4A90E2"/>

    <SolidColorBrush x:Key="Button.Background" Color="#F2FFFFFF"/>
    <SolidColorBrush x:Key="Button.Hover" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="Button.Pressed" Color="#E6FFFFFF"/>

    <SolidColorBrush x:Key="TextBox.Background" Color="#F9FFFFFF"/>
    <SolidColorBrush x:Key="TextBox.Border" Color="#22000000"/>

    <SolidColorBrush x:Key="Link.Foreground" Color="#FF3A6FD8"/>
    <SolidColorBrush x:Key="Icon.Foreground" Color="#FF222222"/>
    <SolidColorBrush x:Key="IconForegroundBrush" Color="#FF222222"/>
    <SolidColorBrush x:Key="IconMutedBrush" Color="#80222222"/>

    <!-- System brushes for dropdowns/menus -->
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FF1A1A1A"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FFE6E6E6"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FF1A1A1A"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FFE6E6E6"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FF1A1A1A"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FF1A1A1A"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FFF3F3F3"/>
</ResourceDictionary>
